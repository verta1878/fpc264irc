#!/bin/sh
# Dummy OS/2 Resource Compiler — creates minimal empty .res
# Usage: wrc [options] input.rc -fo=output.res
OUT=""
for arg in "$@"; do
    case "$arg" in
        -fo=*) OUT="${arg#-fo=}" ;;
        *.res) OUT="$arg" ;;
    esac
done
if [ -n "$OUT" ]; then
    # Create minimal empty Windows .res (works for FPC):
    printf '\x00\x00\x00\x00\x20\x00\x00\x00\xff\xff\x00\x00\xff\xff\x00\x00' > "$OUT"
    printf '\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00' >> "$OUT"
fi
exit 0
