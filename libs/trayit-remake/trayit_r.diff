-function QueryFullProcessImageNameW(hProcess: THandle; dwFlags: DWORD;
-  lpExeName: PWideChar; var lpdwSize: DWORD): BOOL; stdcall;
-  external 'kernel32.dll' name 'QueryFullProcessImageNameW';
+{ Windows XP support: QueryFullProcessImageNameW only exists on Vista+.
+  A static import would stop the exe from LOADING on XP, so both it and
+  the XP fallback (psapi!GetModuleFileNameExW) are resolved at runtime. }
+type
+  TQueryFullProcessImageNameW = function(hProcess: THandle; dwFlags: DWORD;
+    lpExeName: PWideChar; var lpdwSize: DWORD): BOOL; stdcall;
+  TGetModuleFileNameExW = function(hProcess: THandle; hModule: THandle;
+    lpFilename: PWideChar; nSize: DWORD): DWORD; stdcall;
+var
+  pQFPIN : TQueryFullProcessImageNameW = nil;   { Vista+           }
+  pGMFNE : TGetModuleFileNameExW       = nil;   { XP (psapi.dll)   }
+  procResolved: boolean = false;
+
+procedure ResolveProcNameApis;
+var hPsapi: THandle;
+begin
+  if procResolved then Exit;
+  procResolved := true;
+  pQFPIN := TQueryFullProcessImageNameW(
+    GetProcAddress(GetModuleHandle('kernel32.dll'), 'QueryFullProcessImageNameW'));
+  if not Assigned(pQFPIN) then   { objfpc: @procvar = addr of the VAR, never nil }
+  begin
+    hPsapi := LoadLibrary('psapi.dll');
+    if hPsapi <> 0 then
+      pGMFNE := TGetModuleFileNameExW(
+        GetProcAddress(hPsapi, 'GetModuleFileNameExW'));
+  end;
+end;
 function XSendMessageTimeoutW(hw: HWND; Msg: UINT; wp: WPARAM; lp: LPARAM;
