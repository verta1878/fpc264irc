   external 'user32.dll' name 'GetAncestor';
 
+function AppIcon: HICON;
+begin
+  Result := LoadImageW(GetModuleHandleW(nil), PWideChar(1), IMAGE_ICON,
+                       16, 16, LR_DEFAULTCOLOR);
+  if Result = 0 then Result := LoadIcon(0, IDI_APPLICATION);
+end;
