;
; cdll.def
;
LIBRARY CDLL INITINSTANCE
DESCRIPTION 'emx 0.9d dynamically-linked C library -- Copyright (c) 1993-1998 by Eberhard Mattes'

DATA
   MULTIPLE NONSHARED

;
; Lines which are used for multithread DLLs only are marked {MT}
; Lines which are used for single-thread DLLs only are marked {ST}
; Lines which are used for DLLs made with -Zsys only are marked {SYS}
; Lines which are not used for DLLs made with -Zsys are marked {EMX}
;
; To create a multithread DLL, delete all lines containing {ST}
; To create a single-thread DLL, delete all lines containing {MT}
; To create a DLL which uses emx.dll, delete all lines containing {SYS}
; To create a DLL with -Zsys, delete all lines containing {EMX}
;

EXPORTS

;
; The following symbols are used by the startup code and must
; always be exported
;
  _entry1                       ; For startup code
  _entry2                       ; For startup code
  _startup                      ; For startup code
  __ctordtorInit1               ; For startup code
  __ctordtorTerm1               ; For startup code
  atexit                        ; For startup code: atexit()
  exit                          ; For startup code: exit()

;
; The following symbols are used by the startup code and must be
; exported if the DLL does not use emx.dll.  If the DLL does use
; emx.dll, these symbols must not be exported
;
  _emx_init                     ; {SYS} For startup code
  _emx_syscall                  ; {SYS} For startup code

;
; Choose from the following symbols, depending on whether creating
; a single-thread or multithread library
;
  _errno_fun                    ; {MT} For multithread library: errno
  errno                         ; {ST} For single-thread library: errno

;
; The remaining symbols are optional
;

